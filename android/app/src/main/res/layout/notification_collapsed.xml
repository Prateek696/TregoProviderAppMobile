<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="#1e293b"
    android:orientation="horizontal"
    android:padding="12dp"
    android:gravity="center_vertical">

    <!-- App icon — plain View avoids VectorDrawable RemoteViews crash -->
    <TextView
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="@drawable/notif_btn_bg_blue"
        android:text="T"
        android:textColor="#ffffff"
        android:textSize="16sp"
        android:textStyle="bold"
        android:gravity="center" />

    <!-- Text block -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="10dp"
        android:paddingEnd="4dp">

        <TextView
            android:id="@+id/notif_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Trego — Log a job"
            android:textColor="#f1f5f9"
            android:textSize="14sp"
            android:textStyle="bold"
            />

        <TextView
            android:id="@+id/notif_body"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap Voice or Text to log without opening the app"
            android:textColor="#94a3b8"
            android:textSize="12sp"
            android:maxLines="1"
            android:ellipsize="end"
            android:layout_marginTop="2dp" />
    </LinearLayout>

</LinearLayout>
